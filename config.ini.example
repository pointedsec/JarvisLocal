# config.ini - Configuración para OrangePi (8GB RAM) en Español

[Models]
ollama_model = llama3
whisper_model = base
wakeword_model_path = models/jarvis_v2.onnx
piper_model_path = models/es_ES-davefx-medium.onnx
ollama_host = http://localhost:11434

[Functionality]
# Wakewords separados por comas - se aceptan varios
wakewords = hey jarvis, jarvis

# Umbral de detección de wakeword - subir para reducir falsos positivos
wakeword_threshold = 0.40

# Nivel de agresividad del VAD para detección de silencio
# Nivel 1 es más permisivo y evita cortes prematuros
vad_aggressiveness = 1

# Segundos de silencio para detectar fin de habla
silence_seconds = 0.5

# Tiempo de espera antes de timeout
listen_timeout = 5.0

# Pre-buffer de audio en milisegundos
pre_buffer_ms = 300

# Idioma de Whisper para transcripción - 'es' para español
whisper_language = es

# Prompt del sistema - respuestas concisas en español
system_prompt = Eres Jarvis, el asistente personal del grupo de 'El Local'. Respondes SIEMPRE en español con tono ingenioso, sarcástico y muy conciso: una o dos frases máximo, sin relleno. Conoces a los miembros del grupo (úsalo si se identifican): Rodrigo, el menda, el genio detrás de todo esto. Alberto (también 'Borricote' o 'Borrico'), el burro del local, trabaja en Mapfre y rebuzna precioso. Víctor, la oveja del grupo, hace instalaciones eléctricas en Inmosel y es del Atlético de Madrid (perdedor). Topo (o Andrés), rapea en la FMS, juega Minecraft y LoL profesionalmente, dice ser dueño del gato del local pero no lo es, gran programador con varios TOC, una de las cabezas pensantes (no la más importante). Bragado (o Samuel), falangista de extrema derecha, ultra del Real Madrid, tiene una cabra en casa, fanático de la música. Varo, un lobo de Wall Street ya retirado. Elvira, la loca de los gatos, obsesionada con las energías y los chakras (se los puede meter por el culo). Trátalos con burla cariñosa, como un colega más del local.

# Índices de dispositivos de audio (None = usar predeterminado)
device_index = None
piper_output_device_index = 3
gain = 3.0 # Ganancia del micrófono. 1.0 = sin cambio. Subir si el micro es muy bajo.

# Máximo de palabras permitidas en un comando
max_words_per_command = 80

# Duración máxima de una frase hablada (Alexa-style: 20s o cuando el usuario se calle)
max_phrase_duration = 20.0

# Configuración de Whisper optimizada para OrangePi (CPU ARM)
whisper_device = cpu
whisper_compute_type = int8

# Umbrales de Whisper para calidad de transcripción
whisper_avg_logprob = -1.0
whisper_no_speech_prob = 0.65

# Historial de chat - reducido para conservar memoria en OrangePi
max_history_tokens = 1024

# Tamaño del buffer de audio
audio_buffer_size = 400

# Recortar wakeword de la transcripción (recomendado)
trim_wake_word = true

[Performance]
# Forzar recolección de basura cada N conversaciones
gc_interval = 5

# Habilitar perfilado de memoria en modo debug
memory_profiling = false

[Groq]
# Backend de LLM a usar: 'ollama' (local), 'groq' (nube) o 'auto'
# 'auto' usa Groq si hay internet disponible y cae a Ollama si no hay conexión
llm_backend = auto

# Clave de API de Groq (obtener en https://console.groq.com)
groq_api_key =

# Modelo de Groq a usar
groq_model = llama-3.3-70b-versatile